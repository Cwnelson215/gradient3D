{
  "name": "gradient",
  "version": "1.0.0",
  "description": "2D landscape design application",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "concurrently \"npx tsx watch server/index.ts\" \"cd client && npx vite\"",
