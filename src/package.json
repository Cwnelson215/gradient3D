    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "immer": "^10.1.0",
    "konva": "^9.3.0",
    "polygon-clipping": "^0.15.7",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-konva": "^18.2.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "uuid": "^11.0.0",
    "vite": "^6.0.0",
    "zustand": "^5.0.0"
  }
